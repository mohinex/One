# Eurosia One OS Environment Configuration Template

# Network & Host
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Relational database config (PostgreSQL 16)
DATABASE_URL=postgresql://eurosia_user:eurosia_password@localhost:5432/eurosia_one?schema=public

# In-memory caching & queues registry (Redis 7)
REDIS_URL=redis://localhost:6379

# Cryptography & Signing credentials (JWT salt rounds)
JWT_ACCESS_SECRET=your-32-character-or-longer-secret-access-string
JWT_REFRESH_SECRET=your-32-character-or-longer-secret-refresh-string
ENCRYPTION_KEY=32-characters-key-for-AES-encryption-01234567

# Google OAuth Integrations
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# AI Model API integrations keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# AWS S3 or Cloudflare R2 file uploads
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
CDN_URL=

# Nodemailer SMTPS mailing integrations
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@eurosia.one
EMAIL_FROM_NAME="Eurosia One Platform"
