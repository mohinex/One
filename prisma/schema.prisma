// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id                String         @id @default(cuid())
  email             String         @unique
  name              String
  avatarUrl         String?
  passwordHash      String?
  googleId          String?        @unique
  role              String         @default("USER")
  isEmailVerified   Boolean        @default(false)
  emailVerifyToken  String?
  passwordResetToken String?
  passwordResetExpiry DateTime?
  twoFactorSecret   String?
  twoFactorEnabled  Boolean        @default(false)
  isActive          Boolean        @default(true)
  bannedAt          DateTime?
  banReason         String?
  lastLoginAt       DateTime?
  lastLoginIp       String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  chats             Chat[]
  activities        Activity[]
  notifications     Notification[]
  subscription      Subscription?
  usage             UserUsage?
  auditLogs         AuditLog[]
  refreshTokens     RefreshToken[]
  userProfile       UserProfile?
  creditWallet      CreditWallet?
  usageLimit        UsageLimit?
  characters        Character[]
  characterConversations CharacterConversation[]
  characterLogs     CharacterUsageLog[]
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
  revokedAt DateTime?
  userAgent String?
  ipAddress String?
}

model Plan {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  description   String?
  price         Float    @default(0)
  yearlyPrice   Float?
  currency      String   @default("USD")
  stripePriceId String?
  stripeYearlyPriceId String?
  features      String
  // features shape: { chatLimit: number, imageLimit: number, videoLimit: number,
  //   storageGB: number, apiAccess: boolean, prioritySupport: boolean,
  //   customModels: boolean, teamMembers: number }
  isActive      Boolean  @default(true)
  isFeatured    Boolean  @default(false)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  subscriptions Subscription[]
}

model Subscription {
  id                 String             @id @default(cuid())
  userId             String             @unique
  user               User               @relation(fields: [userId], references: [id])
  planId             String
  plan               Plan               @relation(fields: [planId], references: [id])
  stripeSubId        String             @unique
  stripeCustomerId   String
  status             String             @default("ACTIVE")
  billingCycle       String             @default("monthly") // monthly | yearly
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean            @default(false)
  trialStart         DateTime?
  trialEnd           DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
}

model Tool {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String
  icon        String
  iconColor   String   @default("#DC2626")
  category    String
  isActive    Boolean  @default(true)
  isVisible   Boolean  @default(true)
  sortOrder   Int      @default(0)
  requiredPlan String  @default("free") // free | pro | premium
  metadata    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Chat {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title      String    @default("New Chat")
  modelId    String
  systemPrompt String?
  isArchived Boolean   @default(false)
  isPinned   Boolean   @default(false)
  messageCount Int     @default(0)
  totalTokens  Int     @default(0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  messages   Message[]
}

model Message {
  id          String   @id @default(cuid())
  chatId      String
  chat        Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  role        String   // user | assistant | system
  content     String
  inputTokens  Int?
  outputTokens Int?
  model       String?
  finishReason String?
  metadata    String?
  createdAt   DateTime @default(now())
}

model Activity {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String   // chat | image | video | pdf | code | automation | upload
  title       String
  description String?
  resourceUrl String?
  resourceId  String?
  metadata    String?
  createdAt   DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // info | success | warning | error
  title     String
  body      String
  isRead    Boolean  @default(false)
  readAt    DateTime?
  link      String?
  icon      String?
  createdAt DateTime @default(now())
}

model Banner {
  id          String   @id @default(cuid())
  title       String
  subtitle    String?
  imageUrl    String?
  buttonText  String?
  buttonLink  String?
  bgColor     String?
  textColor   String?
  type        String   @default("promo") // hero | promo | announcement
  placement   String   @default("home")  // home | dashboard | global
  targetRole  String?  // null = all, USER, ADMIN
  isActive    Boolean  @default(true)
  startsAt    DateTime?
  endsAt      DateTime?
  sortOrder   Int      @default(0)
  clickCount  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  type      String   @default("string") // string | json | boolean | number | color | url
  group     String   @default("general") // general | appearance | ai | email | security | integrations
  label     String
  isPublic  Boolean  @default(false) // true = sent to frontend without auth
  updatedAt DateTime @updatedAt
  updatedBy String?
}

model AiModel {
  id          String   @id @default(cuid())
  name        String
  modelId     String   @unique
  provider    String   // anthropic | openai | google | stability | custom
  type        String   // chat | image | video | code | embedding
  description String?
  isActive    Boolean  @default(true)
  isDefault   Boolean  @default(false)
  inputCostPer1k  Float? // USD per 1k input tokens
  outputCostPer1k Float? // USD per 1k output tokens
  maxTokens   Int?
  contextWindow Int?
  capabilities String?   // { vision: true, functionCalling: true, streaming: true }
  requiredPlan String  @default("free")
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MediaFile {
  id           String   @id @default(cuid())
  filename     String
  originalName String
  mimeType     String
  size         Int
  url          String   // public CDN URL
  s3Key        String
  s3Bucket     String
  folder       String   @default("general")
  width        Int?     // for images
  height       Int?     // for images
  duration     Float?   // for videos/audio (seconds)
  uploadedBy   String
  isPublic     Boolean  @default(true)
  createdAt    DateTime @default(now())
}

model UserUsage {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  chatCount     Int      @default(0)
  imageCount    Int      @default(0)
  videoCount    Int      @default(0)
  pdfCount      Int      @default(0)
  totalTokensIn  Int     @default(0)
  totalTokensOut Int     @default(0)
  storageUsedBytes BigInt @default(0)
  periodStart   DateTime @default(now())
  periodEnd     DateTime
  updatedAt     DateTime @updatedAt
}

model AuditLog {
  id          String   @id @default(cuid())
  adminId     String
  admin       User     @relation(fields: [adminId], references: [id])
  action      String   // CREATE | UPDATE | DELETE | LOGIN | BROADCAST | SETTINGS_CHANGE
  resource    String   // user | tool | banner | setting | plan | model | media
  resourceId  String?
  before      String?    // snapshot before change
  after       String?    // snapshot after change
  description String
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())
}

model VerificationToken {
  id         String    @id @default(cuid())
  userId     String?   @map("user_id")
  email      String
  tokenHash  String    @unique @map("token_hash")
  type       String    @default("magic-link")
  expiresAt  DateTime  @map("expires_at")
  usedAt     DateTime? @map("used_at")
  ipAddress  String?   @map("ip_address")
  userAgent  String?   @map("user_agent")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@map("verification_tokens")
}

model UserProfile {
  id        String   @id @default(cuid())
  userId    String   @unique @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio       String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("user_profiles")
}

model Workspace {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  name      String
  type      String   @default("personal")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("workspaces")
}

model CreditWallet {
  id        String   @id @default(cuid())
  userId    String   @unique @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance   Int      @default(1000)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("credit_wallets")
}

model UsageLimit {
  id           String   @id @default(cuid())
  userId       String   @unique @map("user_id")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  monthlyLimit Int      @default(100)
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("usage_limits")
}

model Character {
  id              String                 @id @default(cuid())
  userId          String?
  user            User?                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String
  profession      String
  category        String                 @default("General")
  avatar          String?                // URL or initials / background config
  prompt          String
  personality     String
  greeting        String                 @default("Greetings! How can I help you today?")
  instructions    String?
  model           String                 @default("gemini")
  temperature     Float                  @default(0.7)
  tools           String?                // JSON list of tool names
  permissions     String?                // JSON of roles/permissions
  isArchived      Boolean                @default(false)
  isFeatured      Boolean                @default(false)
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  memories        CharacterMemory[]
  conversations   CharacterConversation[]
  logs            CharacterUsageLog[]
}

model CharacterCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CharacterTemplate {
  id           String   @id @default(cuid())
  name         String
  profession   String
  category     String   @default("General")
  avatar       String?
  prompt       String
  personality  String
  greeting     String
  instructions String?
  model        String   @default("gemini")
  temperature  Float    @default(0.7)
  tools        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model CharacterMemory {
  id          String    @id @default(cuid())
  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  content     String
  type        String    @default("fact") // fact | summary | preference
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model CharacterConversation {
  id          String                 @id @default(cuid())
  userId      String
  user        User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  characterId String
  character   Character              @relation(fields: [characterId], references: [id], onDelete: Cascade)
  title       String                 @default("New Conversation")
  isPinned    Boolean                @default(false)
  isArchived  Boolean                @default(false)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  messages    ConversationMessage[]
  summaries   ConversationSummary[]
}

model ConversationMessage {
  id             String                   @id @default(cuid())
  conversationId String
  conversation   CharacterConversation    @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String                   // user | assistant | system
  content        String
  createdAt      DateTime                 @default(now())
  attachments    ConversationAttachment[]
}

model ConversationAttachment {
  id        String              @id @default(cuid())
  messageId String
  message   ConversationMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  name      String
  url       String
  type      String              // image | pdf | doc
  size      Int
  createdAt DateTime            @default(now())
}

model ConversationSummary {
  id             String                @id @default(cuid())
  conversationId String
  conversation   CharacterConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  summary        String
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
}

model CharacterUsageLog {
  id          String    @id @default(cuid())
  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokensUsed  Int       @default(0)
  durationMs  Int       @default(0)
  createdAt   DateTime  @default(now())
}

model SyncQueue {
  id         String   @id @default(cuid())
  action     String   // CREATE | UPDATE | DELETE
  entityType String   // character | conversation | message
  entityId   String
  payload    String   // JSON string of data
  status     String   @default("pending") // pending | synced | failed
  attempts   Int      @default(0)
  error      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

